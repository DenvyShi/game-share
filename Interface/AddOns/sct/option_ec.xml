<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"   xsi:schemaLocation="http://www.blizzard.com/wow/ui/"> 
	<Script file="option_ec.lua"/>
	
	<Button name="DSCTOptionsEC" inherits="GameMenuButtonTemplate" text="DSCT_EC_OPTION">
		<Scripts>
			<OnClick>
				DSCTOptions_Title_Text:SetText(DSCT_EC_OPTION);
				DSCT_HideAllBG();				
				DSCT_ShowBG(1,180,-50,340,360);
				DSCTOptionsFrame_Clear();
				DSCTOptionsFrame_Load(DSCT_OptionCfg_EC);
				DSCT_EC_RefreshLeft();
			</OnClick>
			<OnLoad>				
				this:SetParent("DSCTOptions");
				this:SetPoint("TOPLEFT", "DSCTOptions", "TOPLEFT", 20 ,-280 );
			</OnLoad>
		</Scripts>
	</Button>
</Ui>