	<!-- =================== FRAME LIGNE ================== -->
	<Frame name="SlibLigneTemplate" virtual="true">
		<Size><AbsDimension x="300" y="21"/></Size><!-- 21 = hauteur ligne -->
		<!-- ========== BOUTON G =========== -->
		<Frames>
			<Frame name="SlibCadreBtn" inherits="OptionFrameBoxTemplate" alpha="0.5" virtual="true">
				<Size><AbsDimension x="130" y="24"/></Size><!-- y = hauteur ligne -->
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parent" relativePoint="TOPLEFT">
						<Offset><AbsDimension x="-2" y="1"/></Offset>
					</Anchor>
				</Anchors>
			</Frame>
			<Button name="$parent_BtnTitre" enableMouse="true">
				<Size><AbsDimension x="125" y="19"/></Size><!-- y = hauteur ligne -2 -->
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parent" relativePoint="TOPLEFT">
						<Offset><AbsDimension x="2" y="-2"/></Offset>
					</Anchor>
				</Anchors>
				<Layers>
					<Layer level="BORDER">
						<FontString name="$parent_TxtTitre" inherits="GameFontNormalSmall" nonspacewrap="false" maxLines="0" justifyH="LEFT" justifyV="MIDDLE" bytes="30" text=""><!-- bytes : 显示的字符数 -->
							<Color r="0.9" g="0.9" b="0.4" a="1"/>
							<Anchors>
								<Anchor point="LEFT" relativeTo="$parent" relativePoint="LEFT">
									<Offset><AbsDimension x="0" y="2"/></Offset>
								</Anchor>
							</Anchors>
						</FontString>
					</Layer>
					<Layer level="BACKGROUND">
						<Texture name="$parent_Tex">
							<Color r="0.8" g="0.8" b="0.8" a="0.5"/>
							<Anchors>
								<Anchor point="TOPLEFT" relativeTo="$parent" relativePoint="TOPLEFT">
									<Offset><AbsDimension x="2" y="-2"/></Offset>
								</Anchor>
								<Anchor point="BOTTOMRIGHT" relativeTo="$parent" relativePoint="BOTTOMRIGHT">
									<Offset><AbsDimension x="-4" y="4"/></Offset>
								</Anchor>
							</Anchors>
						</Texture>
					</Layer>
				</Layers>
				<Scripts>
					<OnEnter>
						getglobal(this:GetName().."_Tex"):SetAlpha(1);
					</OnEnter>
					<OnLeave>
						getglobal(this:GetName().."_Tex"):SetAlpha(0.1);
					</OnLeave>
					<OnShow>
						getglobal(this:GetName().."_Tex"):SetAlpha(0.1);
					</OnShow>
					<OnClick>
						slibUIDo(this:GetName());
					</OnClick>
				</Scripts>
			</Button>
			<!-- ========== BOUTON D =========== -->
			<Button name="$parent_BtnCmd" enableMouse="true">
				<Size><AbsDimension x="155" y="16"/></Size><!-- y = hauteur ligne -5 -->
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parent" relativePoint="TOPLEFT">
						<Offset><AbsDimension x="130" y="-3"/></Offset>
					</Anchor>
				</Anchors>
				<Layers>
					<Layer level="BACKGROUND">
						<Texture name="$parent_Tex" setAllPoints="true">
						</Texture>
					</Layer>
					<Layer level="BORDER">
						<FontString name="$parent_TxtCmd" inherits="GameFontNormalSmall" nonspacewrap="false" maxLines="0" justifyH="LEFT" justifyV="MIDDLE" bytes="25" text=""><!-- bytes : 显示的字符数 -->
							<Color r="0.7" g="0.7" b="0.7" a="1"/>
							<Anchors>
								<Anchor point="LEFT" relativeTo="$parent" relativePoint="LEFT">
									<Offset>
										<AbsDimension x="3" y="1"/>
									</Offset>
								</Anchor>
							</Anchors>
						</FontString>
					</Layer>
				</Layers>
				<Scripts>
					<OnEnter>
						getglobal(this:GetName().."_Tex"):SetAlpha(1);
					</OnEnter>
					<OnLeave>
						getglobal(this:GetName().."_Tex"):SetAlpha(0.4);
					</OnLeave>
					<OnShow>
						getglobal(this:GetName().."_Tex"):SetAlpha(0.4);
						getglobal(this:GetName().."_Tex"):SetTexture(0.5,0.5,0.5,0.5);
					</OnShow>
					<OnClick>
						slibUIEdit(this:GetName());
					</OnClick>
				</Scripts>
			</Button>
		</Frames>
