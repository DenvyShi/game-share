		<!-- ================== SCRIPTS==================== -->
		<Scripts>
			<!-- ========== EVENTS ========== -->
			<OnLoad>
				SlibFrame:SetClampedToScreen("true");
				tinsert(UISpecialFrames,"SlibFrame");
				this:RegisterEvent("VARIABLES_LOADED");
 				this:RegisterForDrag("LeftButton");
			</OnLoad>
			<OnEvent>
				if (event == "VARIABLES_LOADED") then
					slibChargement();
				end
			</OnEvent>
			<OnDragStart>
				this:StartMoving();
				this.isMoving = true;
			</OnDragStart>
			<OnDragStop>
				this:StopMovingOrSizing();
				this.isMoving = false;
			</OnDragStop>
			<OnShow>
				SlibTitre:SetText("插件命令控制台");
			</OnShow>
		</Scripts>
