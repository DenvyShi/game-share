		<Scripts>
			<OnLoad>FastQuest_OnLoad();</OnLoad>
			<OnEvent>FastQuest_OnEvent(event,arg1);</OnEvent>
			<OnEscapePressed>
				this:Hide();
			</OnEscapePressed>
			<OnMouseDown>
				if ( ( ( not this.isLocked ) or ( this.isLocked == 0 ) ) and ( arg1 == "LeftButton" ) ) then
					this:StartMoving();
					this.isMoving = true;
				end
			</OnMouseDown>
			<OnMouseUp>
				if ( this.isMoving ) then
					this:StopMovingOrSizing();
					this.isMoving = false;
				end
			</OnMouseUp>
		</Scripts>

