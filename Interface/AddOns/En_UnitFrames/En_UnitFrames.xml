<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
C:\Projects\WoW\Bin\Interface\FrameXML\UI.xsd">
	<Script file="En_UnitFrames.lua"/>
<!-- General -->
	<Frame name="EUF_Frame_Genreal" parent="UIParent" hidden="true">
		<Scripts>
			<OnLoad>
				EUF_Frame_OnLoad();
			</OnLoad>
			<OnEvent>
				EUF_Frame_OnEvent(event);
			</OnEvent>
		</Scripts>
	</Frame>
<!-- Player Frame -->
	<Frame name="EUF_PlayerFrame" parent="PlayerFrame">
		<Frames>
			<Frame>
				<Layers>
					<Layer level="OVERLAY">
						<FontString name="$parentHPPercent" inherits="GameTooltipTextSmall">
							<Anchors>
								<Anchor point="LEFT" relativeTo="PlayerFrameHealthBar" relativePoint="RIGHT">
									<Offset>
										<AbsDimension x="5" y="-5"/>
									</Offset>
								</Anchor>
							</Anchors>
							<Color r="1" g="0.75" b="0"/>
							<Shadow>
								<Offset>
									<AbsDimension x="1" y="-1"/>
								</Offset>
								<Color r="0" g="0" b="0"/>
							</Shadow>
						</FontString>
						<FontString name="$parentMPPercent" inherits="GameTooltipTextSmall">
							<Anchors>
								<Anchor point="TOP" relativeTo="$parentHPPercent" relativePoint="BOTTOM">
									<Offset>
										<AbsDimension x="0" y="0"/>
									</Offset>
								</Anchor>
							</Anchors>
							<Color r="0.75" g="0.75" b="1"/>
							<Shadow>
								<Offset>
									<AbsDimension x="1" y="-1"/>
								</Offset>
								<Color r="0" g="0" b="0"/>
							</Shadow>
						</FontString>
					</Layer>
				</Layers>
				<Scripts>
					<OnLoad>
						this:SetFrameLevel(this:GetFrameLevel() + 1);
					</OnLoad>
				</Scripts>
			</Frame>
		</Frames>
	</Frame>
<!-- TargetFrame -->
	<Frame name="EUF_TargetFrame" parent="TargetFrame">
		<Size>
			<AbsDimension x="200" y="150"/>
		</Size>
		<Anchors>
			<Anchor point="TOPLEFT" relativePoint="TOPLEFT"/>
		</Anchors>
		<Layers>
			<Layer level="OVERLAY">
				<FontString name="$parentHPPercent" inherits="GameTooltipTextSmall" text="">
					<Anchors>
						<Anchor point="RIGHT" relativeTo="TargetFrameHealthBar" relativePoint="LEFT">
							<Offset x="-5" y="-5"/>
						</Anchor>
					</Anchors>
					<Color r="1" g="0.75" b="0"/>
					<Shadow>
						<Offset>
							<AbsDimension x="1" y="-1"/>
						</Offset>
						<Color r="0" g="0" b="0"/>
					</Shadow>
				</FontString>
				<FontString name="$parentMPPercent" inherits="GameTooltipTextSmall" text="">
					<Anchors>
						<Anchor point="TOP" relativeTo="$parentHPPercent" relativePoint="BOTTOM">
							<Offset x="0" y="0"/>
						</Anchor>
					</Anchors>
					<Color r="0.75" g="0.75" b="1"/>
					<Shadow>
						<Offset>
							<AbsDimension x="1" y="-1"/>
						</Offset>
						<Color r="0" g="0" b="0"/>
					</Shadow>
				</FontString>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad>
				this:SetFrameLevel("3");
			</OnLoad>
		</Scripts>
	</Frame>
<!-- Party Frame -->
	<Frame name="EUF_PartyFrameTemplate" frameStrata="MEDIUM" virtual="true">
		<Size>
			<AbsDimension x="220" y="100"/>
		</Size>
		<Anchors>
			<Anchor point="TOPLEFT" relativeTo="$parent" relativePoint="TOPLEFT"/>
		</Anchors>
		<Layers>
			<Layer level="OVERLAY">
				<FontString name="$parentHP" font="Fonts\FZLBJW.TTF" virtual="true">
					<FontHeight>
						<AbsValue val="13"/>
					</FontHeight>
					<Anchors>
						<Anchor point="TOPLEFT">
							<Offset x="119" y="-8"/>
						</Anchor>
					</Anchors>
					<Color r="1" g="0.75" b="0"/>
					<Shadow>
						<Offset>
							<AbsDimension x="1" y="-1"/>
						</Offset>
						<Color r="0" g="0" b="0"/>
					</Shadow>
				</FontString>
				<FontString name="$parentMP" font="Fonts\FZLBJW.TTF" virtual="true">
					<FontHeight>
						<AbsValue val="13"/>
					</FontHeight>
					<Anchors>
						<Anchor point="TOPLEFT">
							<Offset x="119" y="-18"/>
						</Anchor>
					</Anchors>
					<Color r="0.75" g="0.75" b="1"/>
					<Shadow>
						<Offset>
							<AbsDimension x="1" y="-1"/>
						</Offset>
						<Color r="0" g="0" b="0"/>
					</Shadow>
				</FontString>
			</Layer>
		</Layers>
	</Frame>
	<Frame name="EUF_PartyFrame1" inherits="EUF_PartyFrameTemplate" parent="PartyMemberFrame1" id="1"/>
	<Frame name="EUF_PartyFrame2" inherits="EUF_PartyFrameTemplate" parent="PartyMemberFrame2" id="2"/>
	<Frame name="EUF_PartyFrame3" inherits="EUF_PartyFrameTemplate" parent="PartyMemberFrame3" id="3"/>
	<Frame name="EUF_PartyFrame4" inherits="EUF_PartyFrameTemplate" parent="PartyMemberFrame4" id="4"/>
</Ui>